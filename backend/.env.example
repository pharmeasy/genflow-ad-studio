# Google Cloud Config
PROJECT_ID=prj-pe-p-dsml
REGION=global
GCS_BUCKET_NAME=pe-genflow-ad-studio-veo-output

# Model IDs
GEMINI_MODEL=gemini-3.1-pro-preview
IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview

# Veo models (JSON array)
# VEO_MODELS=[{"id":"veo-3.1-generate-preview","label":"Veo 3.1 Preview","description":"Standard — Best quality"},{"id":"veo-3.1-fast-generate-preview","label":"Veo 3.1 Fast Preview","description":"Faster generation"}]

# Seedance 2.0 (ByteDance) — leave SEEDANCE_API_KEY empty to hide from UI
SEEDANCE_API_KEY=
SEEDANCE_API_BASE_URL=https://api.byteplusapi.com
# SEEDANCE_MODELS=[{"id":"seedance-2-0-260128","label":"Seedance 2.0","description":"Standard — Best quality"},{"id":"seedance-2-0-fast-260128","label":"Seedance 2.0 Fast","description":"Faster generation"}]

# Pipeline
OUTPUT_DIR=output
STORYBOARD_QC_THRESHOLD=60
VIDEO_QC_THRESHOLD=6
